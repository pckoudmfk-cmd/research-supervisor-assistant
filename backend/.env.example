# ── Выберите провайдер AI (все бесплатные) ──────────────────────
# groq   — облако, бесплатный tier, регистрация: console.groq.com
# ollama — локально на вашем ПК, установка: ollama.com
# gemini — облако Google, бесплатный tier: aistudio.google.com
AI_PROVIDER=groq

# ── Groq (бесплатно, без карты) ─────────────────────────────────
# Получить ключ: https://console.groq.com → API Keys
GROQ_API_KEY=your_groq_api_key_here

# ── Ollama (полностью локально и бесплатно) ──────────────────────
# Установка: curl https://ollama.com/install.sh | sh
# Затем: ollama pull llama3.2
# OLLAMA_URL=http://localhost:11434/v1   # значение по умолчанию

# ── Google Gemini (бесплатный tier) ─────────────────────────────
# Получить ключ: https://aistudio.google.com/apikey
# GEMINI_API_KEY=your_gemini_api_key_here

# ── Модель (опционально, переопределяет дефолт провайдера) ───────
# AI_MODEL=llama-3.1-8b-instant   # для Groq
# AI_MODEL=llama3.2               # для Ollama
# AI_MODEL=gemini-2.0-flash       # для Gemini
