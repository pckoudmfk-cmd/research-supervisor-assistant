# ── Провайдер AI (по умолчанию Gemini — бесплатно, хорошо работает с русским) ──
AI_PROVIDER=gemini

# ── Google Gemini (бесплатно, 1500 запросов/день) ───────────────────────────
# Получить ключ: https://aistudio.google.com → Get API key → Create API key
GEMINI_API_KEY=your_gemini_api_key_here

# ── Groq (альтернатива, если нужен Groq) ────────────────────────────────────
# AI_PROVIDER=groq
# GROQ_API_KEY=your_groq_api_key_here

# ── Ollama (полностью локально, без интернета) ───────────────────────────────
# AI_PROVIDER=ollama
# OLLAMA_URL=http://localhost:11434/v1
